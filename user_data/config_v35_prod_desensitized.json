{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "verbosity": 1,
  "logfile": "/root/ft_userdata/user_data/logs/freqtrade_v35_prod.log",
  "stake_currency": "USDT",
  "stoploss": -0.5,
  "tradable_balance_ratio": 0.95,
  "dry_run": false,
  "max_open_trades": 30,
  "dry_run_wallet": 30000,
  "stake_amount": "unlimited",
  "cancel_open_orders_on_exit": false,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "can_short": true,
  "export": "signals",
  "backtest_cache_path": "user_data/backtest_results/",
  "dataformat": "json",
  "db_url": "postgresql://freqtrade:***@localhost/freqtrade",
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },
  "exit_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exchange": {
    "name": "bybit",
    "key": "YOUR_API_KEY",
    "secret": "YOUR_API_SECRET",
    "retries": 5,
    "enable_ws": false,
    "ratelimit_sleep": true,
    "timeout": 60000,
    "ccxt_config": {
      "timeout": 60000,
      "httpsProxy": "http://127.0.0.1:18080",
      "rateLimit": 100,
      "options": {
        "defaultType": "future",
        "recvWindow": 60000,
        "adjustForTimeDifference": true
      }
    },
    "ccxt_sync_config": {
      "timeout": 60000,
      "rateLimit": 50
    },
    "ccxt_async_config": {
      "timeout": 60000,
      "rateLimit": 50
    },
    "pair_whitelist": [
      "BTC/USDT:USDT", "ETH/USDT:USDT", "BNB/USDT:USDT", "SOL/USDT:USDT", "XRP/USDT:USDT",
      "ADA/USDT:USDT", "DOGE/USDT:USDT", "LINK/USDT:USDT", "AVAX/USDT:USDT", "DOT/USDT:USDT",
      "LTC/USDT:USDT", "ATOM/USDT:USDT", "NEAR/USDT:USDT", "QNT/USDT:USDT", "MKR/USDT:USDT",
      "UNI/USDT:USDT", "OP/USDT:USDT", "ARB/USDT:USDT", "FIL/USDT:USDT", "MATIC/USDT:USDT",
      "GMX/USDT:USDT", "CRV/USDT:USDT", "AAVE/USDT:USDT", "APT/USDT:USDT", "SUI/USDT:USDT",
      "INJ/USDT:USDT", "TIA/USDT:USDT", "SHIB/USDT:USDT", "PEPE/USDT:USDT", "WIF/USDT:USDT",
      "FLOKI/USDT:USDT", "MAGA/USDT:USDT", "ENA/USDT:USDT", "PUMPFUN/USDT:USDT",
      "PENDLE/USDT:USDT", "MORPHO/USDT:USDT", "SEI/USDT:USDT", "WLD/USDT:USDT", "AR/USDT:USDT",
      "BLUR/USDT:USDT", "COMP/USDT:USDT", "DYDX/USDT:USDT", "GALA/USDT:USDT", "LDO/USDT:USDT",
      "SAND/USDT:USDT", "FLOW/USDT:USDT", "ICP/USDT:USDT", "IMX/USDT:USDT", "JTO/USDT:USDT",
      "JUP/USDT:USDT", "ONDO/USDT:USDT", "PYTH/USDT:USDT", "STX/USDT:USDT", "TON/USDT:USDT",
      "TRX/USDT:USDT", "VIRTUAL/USDT:USDT", "HYPE/USDT:USDT", "GRASS/USDT:USDT", "IOTA/USDT:USDT",
      "SPX/USDT:USDT"
    ],
    "pair_blacklist": [
      "TRUMP/USDT:USDT",
      "BONK/USDT:USDT"
    ],
    "taker": 0.002,
    "maker": 0.002
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 28081,
    "verbosity": "error",
    "enable_openapi": true,
    "jwt_secret_key": "YOUR_JWT_SECRET",
    "ws_token": "YOUR_WS_TOKEN",
    "CORS_origins": [],
    "username": "YOUR_USERNAME",
    "password": "YOUR_PASSWORD"
  },
  "bot_name": "freqtrade_v35_prod",
  "initial_state": "running",
  "force_entry_enable": true,
  "internals": {
    "process_throttle_secs": 5
  },
  "environment": {
    "NUMEXPR_MAX_THREADS": "64"
  },
  "freqai": {
    "enabled": false,
    "feature_parameters": {
      "include_timeframes": [],
      "include_corr_pairlist": []
    },
    "data_split_parameters": {}
  }
}
