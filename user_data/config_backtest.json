{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "verbosity": 0,
  "stake_currency": "USDT",
  "stoploss": -0.025,
  "tradable_balance_ratio": 0.95,
  "dry_run": true,
  "max_open_trades": 20,
  "dry_run_wallet": 10000,
  "stake_amount": "unlimited",
  "cancel_open_orders_on_exit": false,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "can_short": true,
  "export": "trades",
  "backtest_cache_path": "user_data/backtest_results/",
  "dataformat": "json",
  "db_url": "sqlite:///user_data/backtest_results/backtest.db",
  "unfilledtimeout": {
    "entry": 10,
    "exit": 10,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },
  "entry_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1,
    "check_depth_of_market": {
      "enabled": false,
      "bids_to_ask_delta": 1
    }
  },
  "exit_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1
  },
  "exchange": {
    "name": "bybit",
    "key": "",
    "secret": "",
    "retries": 5,
    "enable_ws": false,
    "ratelimit_sleep": true,
    "timeout": 60000,
    "ccxt_config": {
      "enableRateLimit": true,
      "timeout": 60000,
      "httpsProxy": "http://127.0.0.1:18080",
      "wssProxy": "http://127.0.0.1:18080",
      "options": {
        "defaultType": "future",
        "recvWindow": 60000,
        "adjustForTimeDifference": true
      }
    },
    "ccxt_sync_config": {
      "enableRateLimit": true,
      "timeout": 60000,
      "httpsProxy": "http://127.0.0.1:18080"
    },
    "ccxt_async_config": {
      "timeout": 60000,
      "enableRateLimit": true,
      "aiohttp_proxy": "http://127.0.0.1:18080"
    },
    "pair_whitelist": [
      "BTC/USDT:USDT",
      "ETH/USDT:USDT",
      "SOL/USDT:USDT",
      "DOGE/USDT:USDT",
      "ADA/USDT:USDT",
      "NEAR/USDT:USDT",
      "LINK/USDT:USDT",
      "BNB/USDT:USDT",
      "APT/USDT:USDT",
      "DOT/USDT:USDT"
    ],
    "pair_blacklist": [],
    "taker": 0.002,
    "maker": 0.002
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "bot_name": "freqtrade_backtest",
  "initial_state": "running",
  "force_entry_enable": true,
  "internals": {
    "process_throttle_secs": 5
  },
  "environment": {
    "NUMEXPR_MAX_THREADS": "64"
  },
  "freqai": {
    "enabled": true,
    "purge_old_models": true,
    "train_period_days": 90,
    "backtest_period_days": 14,
    "live_retrain_hours": 24,
    "identifier": "alvinchen_freqai_lightgbm_v4_test",
    "feature_parameters": {
      "include_timeframes": [
        "15m",
        "1h"
      ],
      "include_corr_pairlist": [
        "BTC/USDT:USDT",
        "ETH/USDT:USDT"
      ],
      "label_period_candles": 12,
      "include_shifted_candles": 3,
      "DI_threshold": 0.9,
      "weight_factor": 0.9,
      "principal_component_analysis": false,
      "use_SVM_to_remove_outliers": true,
      "svm_params": {
        "shuffle": true,
        "nu": 0.1
      },
      "indicator_periods_candles": [
        10,
        20,
        50,
        100
      ]
    },
    "model_training_parameters": {
      "n_estimators": 500,
      "max_depth": 6,
      "learning_rate": 0.01,
      "num_leaves": 31,
      "min_child_samples": 50,
      "feature_fraction": 0.8,
      "bagging_fraction": 0.8,
      "bagging_freq": 5
    },
    "data_split_parameters": {
      "test_size": 0.25,
      "shuffle": false
    },
    "model_save_type": "joblib",
    "noise_standard_deviation": 0.005
  }
}