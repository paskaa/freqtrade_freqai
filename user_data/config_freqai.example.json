{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "verbosity": 0,
  "stake_currency": "USDT",
  "stoploss": -0.50,
  "tradable_balance_ratio": 0.95,
  "dry_run": false,
  "max_open_trades": 20,
  "dry_run_wallet": 10000,
  "stake_amount": "unlimited",
  "cancel_open_orders_on_exit": false,
  "trading_mode": "futures",
  "margin_mode": "isolated",
  "can_short": true,
  "export": "signals",
  "backtest_cache_path": "user_data/backtest_results/",
  "dataformat": "json",
  "db_url": "postgresql://freqtrade:YOUR_PASSWORD@localhost/freqtrade",
  "exchange": {
    "name": "bybit",
    "key": "YOUR_API_KEY",
    "secret": "YOUR_API_SECRET",
    "retries": 5,
    "enable_ws": false,
    "ratelimit_sleep": true,
    "timeout": 60000,
    "ccxt_config": {
      "timeout": 60000,
      "options": {
        "defaultType": "future",
        "recvWindow": 60000,
        "adjustForTimeDifference": true
      }
    },
    "pair_whitelist": [
      "BTC/USDT:USDT",
      "ETH/USDT:USDT",
      "SOL/USDT:USDT"
    ],
    "pair_blacklist": [],
    "taker": 0.002,
    "maker": 0.002
  },
  "pairlists": [
    {
      "method": "StaticPairList"
    }
  ],
  "api_server": {
    "enabled": true,
    "listen_ip_address": "0.0.0.0",
    "listen_port": 28081,
    "verbosity": "error",
    "enable_openapi": true,
    "jwt_secret_key": "YOUR_JWT_SECRET",
    "ws_token": "YOUR_WS_TOKEN",
    "CORS_origins": [],
    "username": "YOUR_USERNAME",
    "password": "YOUR_PASSWORD"
  },
  "bot_name": "freqtrade_freqai",
  "initial_state": "running",
  "force_entry_enable": true,
  "freqai": {
    "enabled": true,
    "purge_old_models": true,
    "train_period_days": 90,
    "backtest_period_days": 14,
    "live_retrain_hours": 24,
    "identifier": "alvinchen_freqai_lightgbm_v31",
    "feature_parameters": {
      "include_timeframes": ["15m", "1h"],
      "include_corr_pairlist": ["BTC/USDT:USDT", "ETH/USDT:USDT"],
      "label_period_candles": 12,
      "include_shifted_candles": 3,
      "DI_threshold": 0.9,
      "weight_factor": 0.9,
      "principal_component_analysis": false,
      "use_SVM_to_remove_outliers": true,
      "svm_params": {"shuffle": true, "nu": 0.1},
      "indicator_periods_candles": [10, 20, 50, 100]
    },
    "model_training_parameters": {
      "n_estimators": 500,
      "max_depth": 6,
      "learning_rate": 0.01,
      "num_leaves": 31,
      "min_child_samples": 50,
      "feature_fraction": 0.8,
      "bagging_fraction": 0.8,
      "bagging_freq": 5
    },
    "data_split_parameters": {
      "test_size": 0.25,
      "shuffle": false
    },
    "model_save_type": "joblib",
    "noise_standard_deviation": 0.005
  }
}